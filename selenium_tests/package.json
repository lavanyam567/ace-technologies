{
  "name": "ace-technologies-selenium-tests",
  "version": "1.0.0",
  "description": "Comprehensive Selenium E2E Testing Suite for Ace Technologies Web Application",
  "main": "runner.js",
  "scripts": {
    "test": "node runner.js",
    "test:functional": "node runner.js --suite functional",
    "test:ui": "node runner.js --suite ui",
    "test:compatibility": "node runner.js --suite compatibility",
    "test:performance": "node runner.js --suite performance",
    "test:security": "node runner.js --suite security",
    "test:api": "node runner.js --suite api",
    "test:database": "node runner.js --suite database",
    "test:accessibility": "node runner.js --suite accessibility",
    "test:mobile": "node runner.js --suite mobile",
    "test:regression": "node runner.js --suite regression",
    "test:e2e": "node runner.js --suite e2e",
    "test:all": "node runner.js --suite all",
    "test:headed": "cross-env HEADLESS=false node runner.js --suite all",
    "report": "node utils/report-generator.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "selenium-webdriver": "^4.44.0",
    "xlsx": "^0.18.5",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
