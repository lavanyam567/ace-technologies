# Environment variables for Ace Technologies Selenium Test Suite
# Copy this file to .env and fill in the values

# ── App URL ───────────────────────────────────────────────────────────────────
# URL of the running web application.
# For local testing: leave empty (auto-starts static server from build/web)
# For live/staging: set to your deployed URL
E2E_BASE_URL=

# ── Browser ───────────────────────────────────────────────────────────────────
# Set to "false" to see the browser window while tests run
HEADLESS=true

# ── Timeouts ──────────────────────────────────────────────────────────────────
E2E_TIMEOUT_MS=15000

# ── Supabase (for API and Database tests) ────────────────────────────────────
# Find these in your Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Test Credentials (use a dedicated test account, NOT production) ───────────
TEST_EMAIL=test@acetechnologies.com
TEST_PASSWORD=Test@123456
ADMIN_EMAIL=admin@acetechnologies.com
